# Next.js Frontend Environment Variables (Development)
# Copy this file to .env.local and fill in actual values
# NEVER commit .env.local to git

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8787
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe Public Key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx

# Subscription Price IDs (from Stripe)
NEXT_PUBLIC_SUBSCRIPTION_PRICE_MONTHLY=price_xxxx
NEXT_PUBLIC_SUBSCRIPTION_PRICE_ANNUAL=price_xxxx

# Analytics (optional)
NEXT_PUBLIC_ANALYTICS_ID=
