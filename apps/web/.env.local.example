# Next.js Frontend Environment Variables (Development)
# Copy this file to .env.local and fill in actual values
# NEVER commit .env.local to git

# Worker API Base URL (should match where apps/worker runs)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8787

# Cloudflare Stream (should match worker's STREAM_CUSTOMER_DOMAIN)
NEXT_PUBLIC_STREAM_DOMAIN=your-subdomain.cloudflarestream.com

# Google IMA SDK for ad serving
NEXT_PUBLIC_GOOGLE_IMA_SDK_URL=https://imasdk.googleapis.com/js/sdkloader/ima3.js

# Subscription Price IDs (from Stripe)
NEXT_PUBLIC_SUBSCRIPTION_PRICE_MONTHLY=price_xxxx
NEXT_PUBLIC_SUBSCRIPTION_PRICE_ANNUAL=price_xxxx

# Analytics (optional)
NEXT_PUBLIC_ANALYTICS_ID=
